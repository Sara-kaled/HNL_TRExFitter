% =============================================================================
% TRExFitter NOMINAL config — HNL μe VBF
%
% Reads directly from per-process directories (no hadd needed).  Each Sample
% uses NtuplePathSuff to specify the sub-folder and NtupleFile: "*" to grab
% every .root file in it.  If your TRExFitter version doesn't support the
% wildcard, replace NtupleFile: "*" with NtupleFiles: "<file1>,<file2>,..."
%
% Branch-name mapping vs. older config:
%   lep_invMass        ->  mll/1000     (was GeV; framework branch is in MeV)
%   mjj                ->  mjj/1000
%   lep_1stPt          ->  l1_pt/1000
%   lep_2ndPt          ->  l2_pt/1000
%   jet_1stPt          ->  jet1_pt/1000
%   jet_2ndPt          ->  jet2_pt/1000
%   Nbjet              ->  Nbjet_85
%   channel == 2       ->  (l1_flavor==1 && l2_flavor==0)   % μe flavor
%   FinalWeight (MC)   ->  total_weight * globalTriggerEffSF_NOSYS *
%                          weight_leptonSF_tight_NOSYS
%   FinalWeight (fake) ->  fake_weight_nominal              % from AMM
%
% Signal mass points: 3, 15, 40, 60, 80, 100 GeV — one Sample block each.
% For an actual fit, only ONE signal Sample should be active (the others
% are kept for documentation and switched on by changing Regions:).
% =============================================================================

% --------------- %
% ---  JOB    --- %
% --------------- %

Job: "HNL_run2_nominal"
  CmeLabel: "13 TeV"
  POI: "SigXsecOverSM"
  ReadFrom: NTUP

  % Base directory holding ALL the per-process sub-folders.
  % Each Sample below adds its own NtuplePathSuff (the sub-folder name).
  NtuplePaths: "/eos/user/s/sabdelha/freshness/hnl-recon/fresh_ntuples"

  Label: "HNL"
  LumiLabel: "140 fb^{-1}"
  MCweight: "1"
  Lumi: 1
  PlotOptions: "LEFT,NOXERR,NOENDERR"
  NtupleName: "tree"
  DebugLevel: 0
  MCstatThreshold: 0.01
  MCstatConstraint: "Poisson"
  SystControlPlots: TRUE
  SystPruningShape: 0.001
  SystPruningNorm: 0.001
  CorrelationThreshold: 0.20
  HistoChecks: NOCRASH
  SplitHistoFiles: TRUE
  ImageFormat: "pdf"
  SystCategoryTables: TRUE
  RankingPlot: "all"
  RankingMaxNP: 30
  DoSummaryPlot: TRUE
  DoTables: TRUE
  DoSignalRegionsPlot: TRUE
  DoPieChartPlot: TRUE

% --------------- %
% ---  FIT    --- %
% --------------- %

Fit: "fit"
  FitType: SPLUSB
  FitRegion: CRSR
  POIAsimov: 1
  FitBlind: TRUE
  UseMinos: SigXsecOverSM

% --------------- %
% ---  LIMIT  --- %
% --------------- %

Limit: "limit"
  LimitType: ASYMPTOTIC
  LimitBlind: FALSE

% --------------- %
% --- REGIONS --- %
% --------------- %

Region: "HNL_CR_tt"
  Type: CONTROL
  DataType: DATA
  Variable: "mll/1000",30,0,150
  VariableTitle: "m_{ll} [GeV]"
  Selection: "Nbjet_85>=1 && (l1_flavor==1 && l2_flavor==0) && (mll/1000)<150 && (mll/1000)>0 && (mjj/1000)>400 && (l1_pt/1000)>45 && (l2_pt/1000)>15 && (jet1_pt/1000)>35 && (jet2_pt/1000)>20"
  Label: "CR ttbar"
  ShortLabel: "CR ttbar"
  BinWidth: 30

Region: "HNL_CR_ztautau"
  Type: CONTROL
  DataType: DATA
  Variable: "mll/1000",6,0,150
  VariableTitle: "m_{ll} [GeV]"
  Selection: "Nbjet_85==0 && (l1_flavor==1 && l2_flavor==0) && (mll/1000)<150 && (mll/1000)>0 && (mjj/1000)>400 && (l1_pt/1000)<45 && (l1_pt/1000)>35 && (l2_pt/1000)>15 && (jet1_pt/1000)>35 && (jet2_pt/1000)>20"
  Label: "CR Ztt"
  ShortLabel: "CR Z#tau#tau"
  BinWidth: 6

Region: "HNL_SR"
  Type: SIGNAL
  DataType: ASIMOV
  % If you don't yet have a BDT branch, switch the variable to mjj/1000.
  Variable: "BDTScore15",30,-1,1
  VariableTitle: "BDTScore"
  Selection: "Nbjet_85==0 && (l1_flavor==1 && l2_flavor==0) && (mll/1000)<150 && (mll/1000)>0 && (mjj/1000)>400 && (l1_pt/1000)>45 && (l2_pt/1000)>15 && (jet1_pt/1000)>35 && (jet2_pt/1000)>20"
  Label: "SR"
  ShortLabel: "SR"
  TexLabel: "SR"

Region: "HNL_VR"
  Type: VALIDATION
  DataType: DATA
  Variable: "mjj/1000",20,0,400
  VariableTitle: "m_{jj} [GeV]"
  Selection: "Nbjet_85==0 && (l1_flavor==1 && l2_flavor==0) && (mll/1000)<150 && (mll/1000)>0 && (mjj/1000)<400 && (l1_pt/1000)>45 && (l2_pt/1000)>15 && (jet1_pt/1000)>35 && (jet2_pt/1000)>20"
  Label: "VR"
  ShortLabel: "VR"
  TexLabel: "VR"
  BinWidth: 20

% --------------- %
% --- SAMPLES --- %
% --------------- %
%
% NtuplePathSuff   = sub-folder under NtuplePaths
% NtupleFile: "*"  = take every .root file in that sub-folder
% (use NtupleFiles: "name1,name2,..."  if "*" isn't supported in your build)

% ============= Data + data-driven Fake =================================
% Both samples come from the same AMM-weighted ntuple produced by
% AMM/AMM_ElectronOnly.C.  The fake-bg framework writes ONE file with all
% Run-2 data and the per-event AMM weights stored as branches.
%
% Adjust this absolute path if you copy the AMM ntuple elsewhere.
Sample: "Data"
  Title: "Data"
  Type: DATA
  NtuplePath: "/eos/user/s/sabdelha/freshness/hnl-recon/fake_study_final/AMM"
  NtupleFile: "data_with_electron_fake_weights"

Sample: "Fake"
  Type: BACKGROUND
  Title: "Fake e (data-driven)"
  TexTitle: "Fake $e$"
  FillColor: 5
  LineColor: 1
  Smooth: FALSE
  MCweight: "fake_weight_nominal"
  NtuplePath: "/eos/user/s/sabdelha/freshness/hnl-recon/fake_study_final/AMM"
  NtupleFile: "data_with_electron_fake_weights"
  UseMCstat: FALSE

% ============= Signal mass points ======================================
% Each HNL mass has its own sub-folder.  ONE Sample is active per fit
% (controlled by Regions:).  The sample called "HNL" is the one that the
% NormFactor SigXsecOverSM acts on — to switch mass, comment out the
% current Sample and uncomment the desired one.

Sample: "HNL"
  Type: SIGNAL
  Title: "HNL (15 GeV)"
  TexTitle: "HNL 15 GeV"
  FillColor: 2
  LineColor: 2
  NtuplePathSuff: "HNL_15GeV"
  NtupleFile: "*"
  Regions: "HNL_SR","HNL_VR"
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  UseMCstat: FALSE

% ----- The other mass points: copy/paste over the active "HNL" block -----
% Sample: "HNL"
%   Title: "HNL (3 GeV)"
%   NtuplePathSuff: "HNL_3GeV"
%   NtupleFile: "*"
%   ...

% Sample: "HNL"
%   Title: "HNL (40 GeV)"
%   NtuplePathSuff: "HNL_40GeV"
%   NtupleFile: "*"
%   ...

% Sample: "HNL"
%   Title: "HNL (60 GeV)"
%   NtuplePathSuff: "HNL_60GeV"
%   NtupleFile: "*"
%   ...

% Sample: "HNL"
%   Title: "HNL (80 GeV)"
%   NtuplePathSuff: "HNL_80GeV"
%   NtupleFile: "*"
%   ...

% Sample: "HNL"
%   Title: "HNL (100 GeV)"
%   NtuplePathSuff: "HNL_100GeV"
%   NtupleFile: "*"
%   ...

% ============= MC backgrounds (per-process directories) ===============

Sample: "ttbar"
  Type: BACKGROUND
  Title: "#it{t#bar{t}}"
  TexTitle: "$t\bar{t}$"
  FillColor: 0
  LineColor: 1
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtuplePathSuff: "ttbar"
  NtupleFile: "*"

Sample: "wjets"
  Type: BACKGROUND
  Title: "W + jets"
  TexTitle: "W + jets"
  FillColor: 92
  LineColor: 1
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtuplePathSuff: "wjets"
  NtupleFile: "*"

Sample: "singleTop"
  Type: BACKGROUND
  Title: "Single Top"
  FillColor: 62
  LineColor: 1
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtuplePathSuff: "singletop"
  NtupleFile: "*"

% Higgs sub-folder includes HWW (and any other Higgs decay channel)
Sample: "Higgs"
  Type: BACKGROUND
  Title: "Higgs (incl. HWW)"
  TexTitle: "Higgs"
  FillColor: 866
  LineColor: 866
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtuplePathSuff: "higgs"
  NtupleFile: "*"

Sample: "Diboson"
  Type: BACKGROUND
  Title: "Diboson"
  FillColor: 600
  LineColor: 600
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtuplePathSuff: "diboson"
  NtupleFile: "*"

Sample: "Ztautau"
  Type: BACKGROUND
  Title: "Z#rightarrow#tau#tau"
  FillColor: 400
  LineColor: 400
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtuplePathSuff: "ztautau"
  NtupleFile: "*"

% --------------- %
% - NORMFACTORS - %
% --------------- %

NormFactor: "SigXsecOverSM"
  Title: "#it{#mu}(HNL)"
  Nominal: 1
  Min: -100
  Max: 100
  Samples: HNL

NormFactor: "mu_tt"
  Title: "#it{k}(#it{t#bar{t}})"
  Nominal: 1
  Min: 0
  Max: 2
  Samples: ttbar

NormFactor: "mu_ztautau"
  Title: "#it{k}(Z#tau#tau)"
  Nominal: 1
  Min: 0
  Max: 2
  Samples: Ztautau

NormFactor: "muLumi"
  Nominal: 1
  Min: 0
  Max: 100
  Samples: all
  Constant: TRUE

% --------------- %
% - SYSTEMATICS - %
% --------------- %

% Normalisation only

Systematic: "wzjXsec"
  Title: "#it{W}+jets normalization"
  Type: OVERALL
  OverallUp: 0.50
  OverallDown: -0.50
  Samples: wjets
  Category: Theory
  SubCategory: "other-bkg"

Systematic: "stXsec"
  Title: "Single top cross-section"
  Type: OVERALL
  OverallUp:    0.05
  OverallDown: -0.05
  Samples: singleTop
  Category: Theory
  SubCategory: "other-bkg"

Systematic: "ttXsec"
  Title: "#it{t#bar{t}} cross-section"
  Type: OVERALL
  OverallUp:    0.10
  OverallDown: -0.10
  Samples: ttbar
  Category: Theory
  SubCategory: "ttbar-model"

Systematic: "Lumi"
  Title: "Luminosity"
  Type: OVERALL
  OverallUp:    0.0085
  OverallDown: -0.0085
  Samples: all
  Category: Instrumental
  SubCategory: "lumi"

% Fake-rate systematics on the data-driven Fake sample
% (fed by the AMM per-event branches in data_with_electron_fake_weights.root).

Systematic: "FakeMET"
  Title: "Fake MET-dependence"
  Type: HISTO
  Samples: Fake
  WeightSufUp:   "fake_weight_MET_up / fake_weight_nominal"
  WeightSufDown: "fake_weight_MET_down / fake_weight_nominal"
  Symmetrisation: TWOSIDED
  Category: "Fake"
  SubCategory: "FakeShape"

Systematic: "FakeComp"
  Title: "Fake composition"
  Type: HISTO
  Samples: Fake
  WeightSufUp:   "fake_weight_comp_up / fake_weight_nominal"
  WeightSufDown: "fake_weight_comp_down / fake_weight_nominal"
  Symmetrisation: TWOSIDED
  Category: "Fake"
  SubCategory: "FakeShape"

Systematic: "FakeReal"
  Title: "Prompt-MC subtraction"
  Type: HISTO
  Samples: Fake
  WeightSufUp:   "fake_weight_real_up / fake_weight_nominal"
  WeightSufDown: "fake_weight_real_down / fake_weight_nominal"
  Symmetrisation: TWOSIDED
  Category: "Fake"
  SubCategory: "FakeNorm"

Systematic: "FakeStat"
  Title: "Fake statistical"
  Type: HISTO
  Samples: Fake
  WeightSufUp:   "fake_weight_statUp / fake_weight_nominal"
  WeightSufDown: "fake_weight_statDown / fake_weight_nominal"
  Symmetrisation: TWOSIDED
  Category: "Fake"
  SubCategory: "FakeStat"
