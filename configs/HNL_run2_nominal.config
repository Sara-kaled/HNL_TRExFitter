% =============================================================================
% TRExFitter NOMINAL config — HNL μe VBF
%
% Branches updated to match the fake-bg framework's output ntuples
% (data_with_electron_fake_weights.root + per-process MC ntuples).
%
% Branch-name mapping vs. older config:
%   lep_invMass        ->  mll/1000     (was GeV; new ntuple is in MeV)
%   mjj                ->  mjj/1000
%   lep_1stPt          ->  l1_pt/1000
%   lep_2ndPt          ->  l2_pt/1000
%   jet_1stPt          ->  jet1_pt/1000
%   jet_2ndPt          ->  jet2_pt/1000
%   Nbjet              ->  Nbjet_85
%   channel == 2       ->  (l1_flavor==1 && l2_flavor==0)   % μe flavor
%   FinalWeight (MC)   ->  total_weight * globalTriggerEffSF_NOSYS *
%                          weight_leptonSF_tight_NOSYS
%   FinalWeight (fake) ->  fake_weight_nominal              % from AMM
% =============================================================================

% --------------- %
% ---  JOB    --- %
% --------------- %

Job: "HNL_mc20e_15GeV_lim"
  CmeLabel: "13 TeV"
  POI: "SigXsecOverSM"
  ReadFrom: NTUP
  NtuplePaths: "path_to_your_ntuples"
  Label: "HNL"
  LumiLabel: "140 fb^{-1}"
  MCweight: "1"
  Lumi: 1
  PlotOptions: "LEFT,NOXERR,NOENDERR"
  NtupleName: "tree"        % framework writes TTree named 'tree'
  DebugLevel: 0
  MCstatThreshold: 0.01
  MCstatConstraint: "Poisson"
  SystControlPlots: TRUE
  SystPruningShape: 0.001
  SystPruningNorm: 0.001
  CorrelationThreshold: 0.20
  HistoChecks: NOCRASH
  SplitHistoFiles: TRUE
  ImageFormat: "pdf"
  SystCategoryTables: TRUE
  RankingPlot: "all"
  RankingMaxNP: 30
  DoSummaryPlot: TRUE
  DoTables: TRUE
  DoSignalRegionsPlot: TRUE
  DoPieChartPlot: TRUE

% --------------- %
% ---  FIT    --- %
% --------------- %

Fit: "fit"
  FitType: SPLUSB
  FitRegion: CRSR
  POIAsimov: 1
  FitBlind: TRUE
  UseMinos: SigXsecOverSM

% --------------- %
% ---  LIMIT  --- %
% --------------- %

Limit: "limit"
  LimitType: ASYMPTOTIC
  LimitBlind: FALSE

% --------------- %
% --- REGIONS --- %
% --------------- %
%
% All cuts use μe flavor (l1_flavor==1 && l2_flavor==0).  Branch values from
% the framework ntuples are in MeV; we convert in-place with `/1000` so the
% TRExFitter histograms display in GeV.

Region: "HNL_CR_tt"
  Type: CONTROL
  DataType: DATA
  Variable: "mll/1000",30,0,150
  VariableTitle: "m_{ll} [GeV]"
  Selection: "Nbjet_85>=1 && (l1_flavor==1 && l2_flavor==0) && (mll/1000)<150 && (mll/1000)>0 && (mjj/1000)>400 && (l1_pt/1000)>45 && (l2_pt/1000)>15 && (jet1_pt/1000)>35 && (jet2_pt/1000)>20"
  Label: "CR ttbar"
  ShortLabel: "CR ttbar"
  NtuplePathSuff: "your_directory"
  BinWidth: 30

Region: "HNL_CR_ztautau"
  Type: CONTROL
  DataType: DATA
  Variable: "mll/1000",6,0,150
  VariableTitle: "m_{ll} [GeV]"
  Selection: "Nbjet_85==0 && (l1_flavor==1 && l2_flavor==0) && (mll/1000)<150 && (mll/1000)>0 && (mjj/1000)>400 && (l1_pt/1000)<45 && (l1_pt/1000)>35 && (l2_pt/1000)>15 && (jet1_pt/1000)>35 && (jet2_pt/1000)>20"
  Label: "CR Ztt"
  ShortLabel: "CR Z#tau#tau"
  NtuplePathSuff: "your_directory"
  BinWidth: 6

Region: "HNL_SR"
  Type: SIGNAL
  DataType: ASIMOV
  % BDTScore15 was the original SR observable.  If you don't yet have a BDT
  % branch, fall back to mjj as a placeholder.
  Variable: "BDTScore15",30,-1,1
  VariableTitle: "BDTScore"
  Selection: "Nbjet_85==0 && (l1_flavor==1 && l2_flavor==0) && (mll/1000)<150 && (mll/1000)>0 && (mjj/1000)>400 && (l1_pt/1000)>45 && (l2_pt/1000)>15 && (jet1_pt/1000)>35 && (jet2_pt/1000)>20"
  Label: "SR"
  ShortLabel: "SR"
  TexLabel: "SR"
  NtuplePathSuff: "your_directory"

Region: "HNL_VR"
  Type: VALIDATION
  DataType: DATA
  Variable: "mjj/1000",20,0,400
  VariableTitle: "m_{jj} [GeV]"
  Selection: "Nbjet_85==0 && (l1_flavor==1 && l2_flavor==0) && (mll/1000)<150 && (mll/1000)>0 && (mjj/1000)<400 && (l1_pt/1000)>45 && (l2_pt/1000)>15 && (jet1_pt/1000)>35 && (jet2_pt/1000)>20"
  Label: "VR"
  ShortLabel: "VR"
  TexLabel: "VR"
  NtuplePathSuff: "your_directory"
  BinWidth: 20

% --------------- %
% --- SAMPLES --- %
% --------------- %

% Data — read from the AMM-weighted ntuple (per-event fake_weight_* branches
% are still there but unused for the Data sample).
Sample: "Data"
  Title: "Data"
  Type: DATA
  NtupleFile: "data_with_electron_fake_weights"

% Fake-electron background — same data ntuple, weighted by the AMM weight.
% This replaces a multijet MC template; it's the data-driven contribution.
Sample: "Fake"
  Type: BACKGROUND
  Title: "Fake e (data-driven)"
  TexTitle: "Fake $e$"
  FillColor: 5
  LineColor: 1
  Smooth: FALSE
  MCweight: "fake_weight_nominal"
  NtupleFile: "data_with_electron_fake_weights"
  UseMCstat: FALSE

% Signal — keep the original signal ntuple naming.  MCweight expression to
% match the framework's lepton SF chain (replace ScaledWeight15 if you have it).
Sample: "HNL"
  Type: SIGNAL
  Title: "HNL"
  TexTitle: "HNL"
  FillColor: 2
  LineColor: 2
  NtupleFile: "signal_604535_run2"
  Regions: "HNL_SR","HNL_VR"
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  UseMCstat: FALSE

% Prompt MC backgrounds — same MCweight expression.  Adjust NtupleFile names
% to your hadded files; one per process.
Sample: "ttbar"
  Type: BACKGROUND
  Title: "#it{t#bar{t}}"
  TexTitle: "$t\bar{t}$"
  FillColor: 0
  LineColor: 1
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtupleFile: "ttbar_run2"

Sample: "wjets"
  Type: BACKGROUND
  Title: "W + jets"
  TexTitle: "W + jets"
  FillColor: 92
  LineColor: 1
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtupleFile: "wjets_run2"

Sample: "singleTop"
  Type: BACKGROUND
  Title: "Single Top"
  FillColor: 62
  LineColor: 1
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtupleFile: "singletop_run2"

Sample: "Higgs"
  Type: BACKGROUND
  Title: "VBF H#rightarrowWW"
  FillColor: 866
  LineColor: 866
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtupleFile: "higgs_run2"

Sample: "Diboson"
  Type: BACKGROUND
  Title: "Diboson"
  FillColor: 600
  LineColor: 600
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtupleFile: "diboson_run2"

Sample: "Ztautau"
  Type: BACKGROUND
  Title: "Z#rightarrow#tau#tau"
  FillColor: 400
  LineColor: 400
  MCweight: "total_weight * globalTriggerEffSF_NOSYS * weight_leptonSF_tight_NOSYS"
  Smooth: TRUE
  NtupleFile: "ztautau_run2"

% --------------- %
% - NORMFACTORS - %
% --------------- %

NormFactor: "SigXsecOverSM"
  Title: "#it{#mu}(HNL)"
  Nominal: 1
  Min: -100
  Max: 100
  Samples: HNL

NormFactor: "mu_tt"
  Title: "#it{k}(#it{t#bar{t}})"
  Nominal: 1
  Min: 0
  Max: 2
  Samples: ttbar

NormFactor: "mu_ztautau"
  Title: "#it{k}(Z#tau#tau)"
  Nominal: 1
  Min: 0
  Max: 2
  Samples: Ztautau

NormFactor: "muLumi"
  Nominal: 1
  Min: 0
  Max: 100
  Samples: all
  Constant: TRUE

% --------------- %
% - SYSTEMATICS - %
% --------------- %
%
% NOMINAL config: only normalization-only systematics (no shape NPs).
% The full set of weight-based shape systematics lives in
% HNL_run2_allSYS.config.

% Normalisation only

Systematic: "wzjXsec"
  Title: "#it{W}+jets normalization"
  Type: OVERALL
  OverallUp: 0.50
  OverallDown: -0.50
  Samples: wjets
  Category: Theory
  SubCategory: "other-bkg"

Systematic: "stXsec"
  Title: "Single top cross-section"
  Type: OVERALL
  OverallUp:    0.05
  OverallDown: -0.05
  Samples: singleTop
  Category: Theory
  SubCategory: "other-bkg"

Systematic: "ttXsec"
  Title: "#it{t#bar{t}} cross-section"
  Type: OVERALL
  OverallUp:    0.10
  OverallDown: -0.10
  Samples: ttbar
  Category: Theory
  SubCategory: "ttbar-model"

Systematic: "Lumi"
  Title: "Luminosity"
  Type: OVERALL
  OverallUp:    0.0085
  OverallDown: -0.0085
  Samples: all
  Category: Instrumental
  SubCategory: "lumi"

% Fake-rate systematics on the data-driven Fake sample
% (fed by the AMM per-event branches in data_with_electron_fake_weights.root).
%
% Each NP varies the per-event AMM weight by switching from
% fake_weight_nominal to fake_weight_<src>_<up/down>.

Systematic: "FakeMET"
  Title: "Fake MET-dependence"
  Type: HISTO
  Samples: Fake
  WeightSufUp:   "fake_weight_MET_up / fake_weight_nominal"
  WeightSufDown: "fake_weight_MET_down / fake_weight_nominal"
  Symmetrisation: TWOSIDED
  Category: "Fake"
  SubCategory: "FakeShape"

Systematic: "FakeComp"
  Title: "Fake composition"
  Type: HISTO
  Samples: Fake
  WeightSufUp:   "fake_weight_comp_up / fake_weight_nominal"
  WeightSufDown: "fake_weight_comp_down / fake_weight_nominal"
  Symmetrisation: TWOSIDED
  Category: "Fake"
  SubCategory: "FakeShape"

Systematic: "FakeReal"
  Title: "Prompt-MC subtraction"
  Type: HISTO
  Samples: Fake
  WeightSufUp:   "fake_weight_real_up / fake_weight_nominal"
  WeightSufDown: "fake_weight_real_down / fake_weight_nominal"
  Symmetrisation: TWOSIDED
  Category: "Fake"
  SubCategory: "FakeNorm"

Systematic: "FakeStat"
  Title: "Fake statistical"
  Type: HISTO
  Samples: Fake
  WeightSufUp:   "fake_weight_statUp / fake_weight_nominal"
  WeightSufDown: "fake_weight_statDown / fake_weight_nominal"
  Symmetrisation: TWOSIDED
  Category: "Fake"
  SubCategory: "FakeStat"
